#!/usr/bin/env bash
set -euo pipefail
APP=dragon

MUTED='\033[0;2m'
RED='\033[0;31m'
ORANGE='\033[38;5;214m'
NC='\033[0m' # No Color

usage() {
    cat <<EOF
DragonCode Installer

Usage: install.sh [options]

Options:
    -h, --help              Display this help message
    -v, --version <version> Install a specific version (e.g., 1.0.180)
    -b, --binary <path>     Install from a local binary instead of downloading
        --no-modify-path    Don't modify shell config files (.zshrc, .bashrc, etc.)

Examples:
    curl -fsSL https://raw.githubusercontent.com/VELLORAAI/dragoncode-public-dist/main/install | bash
    curl -fsSL https://raw.githubusercontent.com/VELLORAAI/dragoncode-public-dist/main/install | bash -s -- --version 1.0.0
    ./install --binary /path/to/dragon
EOF
}

requested_version=${VERSION:-}
no_modify_path=false
binary_path=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        -v|--version)
            if [[ -n "${2:-}" ]]; then
                requested_version="$2"
                shift 2
            else
                echo -e "${RED}Error: --version requires a version argument${NC}"
                exit 1
            fi
            ;;
        -b|--binary)
            if [[ -n "${2:-}" ]]; then
                binary_path="$2"
                shift 2
            else
                echo -e "${RED}Error: --binary requires a path argument${NC}"
                exit 1
            fi
            ;;
        --no-modify-path)
            no_modify_path=true
            shift
            ;;
        *)
            echo -e "${ORANGE}Warning: Unknown option '$1'${NC}" >&2
            shift
            ;;
    esac
done

INSTALL_DIR=$HOME/.dragoncode/bin
mkdir -p "$INSTALL_DIR"

# Installed executable name; Windows binaries are dragon.exe (set below once the
# OS is known). `dragon` on PATH resolves dragon.exe on Windows.
bin_name="dragon"

# If --binary is provided, skip all download/detection logic
if [ -n "$binary_path" ]; then
    if [ ! -f "$binary_path" ]; then
        echo -e "${RED}Error: Binary not found at ${binary_path}${NC}"
        exit 1
    fi
    specific_version="local"
else
    raw_os=$(uname -s)
    os=$(echo "$raw_os" | tr '[:upper:]' '[:lower:]')
    case "$raw_os" in
      Darwin*) os="darwin" ;;
      Linux*) os="linux" ;;
      MINGW*|MSYS*|CYGWIN*) os="windows" ;;
    esac

    arch=$(uname -m)
    if [[ "$arch" == "aarch64" ]]; then
      arch="arm64"
    fi
    if [[ "$arch" == "x86_64" ]]; then
      arch="x64"
    fi

    if [ "$os" = "darwin" ] && [ "$arch" = "x64" ]; then
      rosetta_flag=$(sysctl -n sysctl.proc_translated 2>/dev/null || echo 0)
      if [ "$rosetta_flag" = "1" ]; then
        arch="arm64"
      fi
    fi

    combo="$os-$arch"
    case "$combo" in
      linux-x64|linux-arm64|darwin-arm64|darwin-x64|windows-x64)
        ;;
      *)
        echo -e "${RED}Unsupported OS/Arch: $os/$arch${NC}"
        exit 1
        ;;
    esac

    archive_ext=".zip"
    if [ "$os" = "linux" ]; then
      archive_ext=".tar.gz"
    fi

    # Windows release binaries are dragon.exe (inside dragon-windows-x64.zip).
    if [ "$os" = "windows" ]; then
      bin_name="dragon.exe"
    fi

    is_musl=false
    if [ "$os" = "linux" ]; then
      if [ -f /etc/alpine-release ]; then
        is_musl=true
      fi

      if command -v ldd >/dev/null 2>&1; then
        if ldd --version 2>&1 | grep -qi musl; then
          is_musl=true
        fi
      fi
    fi

    needs_baseline=false
    if [ "$arch" = "x64" ]; then
      if [ "$os" = "linux" ]; then
        if ! grep -qwi avx2 /proc/cpuinfo 2>/dev/null; then
          needs_baseline=true
        fi
      fi

      if [ "$os" = "darwin" ]; then
        avx2=$(sysctl -n hw.optional.avx2_0 2>/dev/null || echo 0)
        if [ "$avx2" != "1" ]; then
          needs_baseline=true
        fi
      fi

      if [ "$os" = "windows" ]; then
        ps="(Add-Type -MemberDefinition \"[DllImport(\"\"kernel32.dll\"\")] public static extern bool IsProcessorFeaturePresent(int ProcessorFeature);\" -Name Kernel32 -Namespace Win32 -PassThru)::IsProcessorFeaturePresent(40)"
        out=""
        if command -v powershell.exe >/dev/null 2>&1; then
          out=$(powershell.exe -NoProfile -NonInteractive -Command "$ps" 2>/dev/null || true)
        elif command -v pwsh >/dev/null 2>&1; then
          out=$(pwsh -NoProfile -NonInteractive -Command "$ps" 2>/dev/null || true)
        fi
        out=$(echo "$out" | tr -d '\r' | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')
        if [ "$out" != "true" ] && [ "$out" != "1" ]; then
          needs_baseline=true
        fi
      fi
    fi

    target="$os-$arch"
    if [ "$needs_baseline" = "true" ]; then
      target="$target-baseline"
    fi
    if [ "$is_musl" = "true" ]; then
      target="$target-musl"
    fi

    filename="$APP-$target$archive_ext"


    if [ "$os" = "linux" ]; then
        if ! command -v tar >/dev/null 2>&1; then
             echo -e "${RED}Error: 'tar' is required but not installed.${NC}"
             exit 1
        fi
    else
        if ! command -v unzip >/dev/null 2>&1; then
            echo -e "${RED}Error: 'unzip' is required but not installed.${NC}"
            exit 1
        fi
    fi

    if [ -z "$requested_version" ]; then
        release_base="https://github.com/VELLORAAI/dragoncode-public-dist/releases/latest/download"
        specific_version=$(curl -s https://api.github.com/repos/VELLORAAI/dragoncode-public-dist/releases/latest | sed -n 's/.*"tag_name": *"v\([^"]*\)".*/\1/p')

        if [[ $? -ne 0 || -z "$specific_version" ]]; then
            echo -e "${RED}Failed to fetch version information${NC}"
            exit 1
        fi
    else
        # Strip leading 'v' if present
        requested_version="${requested_version#v}"
        release_base="https://github.com/VELLORAAI/dragoncode-public-dist/releases/download/v${requested_version}"
        specific_version=$requested_version

        # Verify the release exists before downloading
        http_status=$(curl -sI -o /dev/null -w "%{http_code}" "https://github.com/VELLORAAI/dragoncode-public-dist/releases/tag/v${requested_version}")
        if [ "$http_status" = "404" ]; then
            echo -e "${RED}Error: Release v${requested_version} not found${NC}"
            echo -e "${MUTED}Available releases: https://github.com/VELLORAAI/dragoncode-public-dist/releases${NC}"
            exit 1
        fi
    fi

    # Resolve the actual asset. We may have appended a -baseline (older x86-64,
    # no AVX2) or -musl (Alpine) suffix above, but those variants are not always
    # published. Probe the optimized asset first and fall back to the plain
    # "$os-$arch" build so an older CPU / musl libc gets a clean warning and a
    # working binary instead of a hard 404. Candidates are tried in preference
    # order; the first that exists wins.
    plain_filename="$APP-$os-$arch$archive_ext"
    asset_exists() {
        # A published GitHub release asset resolves (302) to a CDN URL; a missing
        # one returns 404. -L follows the redirect so we observe the final 200.
        local code
        code=$(curl -sIL -o /dev/null -w "%{http_code}" "$1" 2>/dev/null || echo 000)
        [ "$code" = "200" ]
    }
    resolved=""
    for candidate in "$filename" "$plain_filename"; do
        if asset_exists "$release_base/$candidate"; then
            resolved="$candidate"
            break
        fi
    done
    if [ -z "$resolved" ]; then
        echo -e "${RED}Error: no matching release asset for $os-$arch (tried: $filename${NC}$([ "$plain_filename" != "$filename" ] && echo ", $plain_filename")${RED})${NC}"
        echo -e "${MUTED}Available assets: https://github.com/VELLORAAI/dragoncode-public-dist/releases${NC}"
        exit 1
    fi
    if [ "$resolved" != "$filename" ]; then
        echo -e "${ORANGE}Note: an optimized build ($filename) isn't published for your CPU/libc; using the standard build ($resolved). It requires a modern x86-64 CPU (AVX2) and glibc.${NC}" >&2
        filename="$resolved"
    fi
    url="$release_base/$filename"
fi

print_message() {
    local level=$1
    local message=$2
    local color=""

    case $level in
        info) color="${NC}" ;;
        warning) color="${NC}" ;;
        error) color="${RED}" ;;
    esac

    echo -e "${color}${message}${NC}"
}

check_version() {
    if command -v dragon >/dev/null 2>&1; then
        dragon_path=$(which dragon)

        ## Check the installed version
        installed_version=$(dragon --version 2>/dev/null || echo "")

        if [[ "$installed_version" != "$specific_version" ]]; then
            print_message info "${MUTED}Installed version: ${NC}$installed_version."
        else
            print_message info "${MUTED}Version ${NC}$specific_version${MUTED} already installed"
            exit 0
        fi
    fi
}

unbuffered_sed() {
    if echo | sed -u -e "" >/dev/null 2>&1; then
        sed -nu "$@"
    elif echo | sed -l -e "" >/dev/null 2>&1; then
        sed -nl "$@"
    else
        local pad="$(printf "\n%512s" "")"
        sed -ne "s/$/\\${pad}/" "$@"
    fi
}

print_progress() {
    local bytes="$1"
    local length="$2"
    [ "$length" -gt 0 ] || return 0

    local width=50
    local percent=$(( bytes * 100 / length ))
    [ "$percent" -gt 100 ] && percent=100
    local on=$(( percent * width / 100 ))
    local off=$(( width - on ))

    local filled=$(printf "%*s" "$on" "")
    filled=${filled// /■}
    local empty=$(printf "%*s" "$off" "")
    empty=${empty// /･}

    printf "\r${ORANGE}%s%s %3d%%${NC}" "$filled" "$empty" "$percent" >&4
}

download_with_progress() {
    local url="$1"
    local output="$2"

    if [ -t 2 ]; then
        exec 4>&2
    else
        exec 4>/dev/null
    fi

    local tmp_dir=${TMPDIR:-/tmp}
    local basename="${tmp_dir}/dragon_install_$$"
    local tracefile="${basename}.trace"

    rm -f "$tracefile"
    mkfifo "$tracefile"

    # Hide cursor
    printf "\033[?25l" >&4

    trap "trap - RETURN; rm -f \"$tracefile\"; printf '\033[?25h' >&4; exec 4>&-" RETURN

    (
        curl --trace-ascii "$tracefile" -s -L -o "$output" "$url"
    ) &
    local curl_pid=$!

    unbuffered_sed \
        -e 'y/ACDEGHLNORTV/acdeghlnortv/' \
        -e '/^0000: content-length:/p' \
        -e '/^<= recv data/p' \
        "$tracefile" | \
    {
        local length=0
        local bytes=0

        while IFS=" " read -r -a line; do
            [ "${#line[@]}" -lt 2 ] && continue
            local tag="${line[0]} ${line[1]}"

            if [ "$tag" = "0000: content-length:" ]; then
                length="${line[2]}"
                length=$(echo "$length" | tr -d '\r')
                bytes=0
            elif [ "$tag" = "<= recv" ]; then
                local size="${line[3]}"
                bytes=$(( bytes + size ))
                if [ "$length" -gt 0 ]; then
                    print_progress "$bytes" "$length"
                fi
            fi
        done
    }

    wait $curl_pid
    local ret=$?
    echo "" >&4
    return $ret
}

# Verify a downloaded archive against the SHA256 digest GitHub publishes for the
# release asset (best-effort supply-chain integrity on top of TLS). A genuine
# mismatch ALWAYS aborts. When the tools to check are absent (no sha256sum/shasum,
# or neither jq nor python3 to read the API, or the API is unreachable) it warns
# and continues rather than breaking installs in minimal environments.
verify_checksum() {
    local file="$1" fname="$2" version="$3"

    local sha_tool=""
    if command -v sha256sum >/dev/null 2>&1; then
        sha_tool="sha256sum"
    elif command -v shasum >/dev/null 2>&1; then
        sha_tool="shasum -a 256"
    fi
    if [ -z "$sha_tool" ]; then
        print_message warning "No sha256 tool (sha256sum/shasum) found; skipping checksum verification."
        return 0
    fi

    local api="https://api.github.com/repos/VELLORAAI/dragoncode-public-dist/releases/tags/v${version}"
    local json expected=""
    json=$(curl -fsSL "$api" 2>/dev/null) || json=""
    if [ -n "$json" ]; then
        if command -v jq >/dev/null 2>&1; then
            expected=$(printf '%s' "$json" | jq -r --arg n "$fname" '.assets[] | select(.name==$n) | .digest // empty' 2>/dev/null | sed 's/^sha256://')
        elif command -v python3 >/dev/null 2>&1; then
            expected=$(printf '%s' "$json" | python3 -c 'import sys, json
try:
    data = json.load(sys.stdin)
    name = sys.argv[1]
    for a in data.get("assets", []):
        if a.get("name") == name:
            print((a.get("digest") or "").replace("sha256:", ""))
            break
except Exception:
    pass' "$fname" 2>/dev/null)
        fi
    fi
    if [ -z "$expected" ]; then
        print_message warning "Could not fetch the expected checksum for ${fname}; skipping verification."
        return 0
    fi

    local actual
    actual=$($sha_tool "$file" 2>/dev/null | awk '{print $1}')
    if [ "$actual" != "$expected" ]; then
        print_message error "Checksum mismatch for ${fname} - aborting install (possible corrupted or tampered download).\n  expected: sha256:${expected}\n  actual:   sha256:${actual}"
        rm -rf "$(dirname "$file")"
        exit 1
    fi
    print_message info "${MUTED}Verified checksum (sha256).${NC}"
}

download_and_install() {
    print_message info "\n${MUTED}Installing ${NC}DragonCode ${MUTED}version: ${NC}$specific_version"
    local tmp_dir="${TMPDIR:-/tmp}/dragon_install_$$"
    mkdir -p "$tmp_dir"

    if [[ "$os" == "windows" ]] || ! [ -t 2 ] || ! download_with_progress "$url" "$tmp_dir/$filename"; then
        # Fallback to standard curl on Windows, non-TTY environments, or if custom progress fails
        curl -# -L -o "$tmp_dir/$filename" "$url"
    fi

    # Integrity gate before we extract and run anything from the archive.
    verify_checksum "$tmp_dir/$filename" "$filename" "$specific_version"

    if [ "$os" = "linux" ]; then
        tar -xzf "$tmp_dir/$filename" -C "$tmp_dir"
    else
        unzip -q "$tmp_dir/$filename" -d "$tmp_dir"
    fi

    mv "$tmp_dir/$bin_name" "${INSTALL_DIR}/${bin_name}"
    chmod 755 "${INSTALL_DIR}/${bin_name}" 2>/dev/null || true
    rm -rf "$tmp_dir"
}

install_from_binary() {
    print_message info "\n${MUTED}Installing ${NC}DragonCode ${MUTED}from: ${NC}$binary_path"
    cp "$binary_path" "${INSTALL_DIR}/${bin_name}"
    chmod 755 "${INSTALL_DIR}/${bin_name}" 2>/dev/null || true
}

if [ -n "$binary_path" ]; then
    install_from_binary
else
    check_version
    download_and_install
fi


add_to_path() {
    local config_file=$1
    local command=$2

    if grep -Fxq "$command" "$config_file"; then
        print_message info "Command already exists in $config_file, skipping write."
    elif [[ -w $config_file ]]; then
        echo -e "\n# dragoncode" >> "$config_file"
        echo "$command" >> "$config_file"
        print_message info "${MUTED}Successfully added ${NC}DragonCode ${MUTED}to \$PATH in ${NC}$config_file"
    else
        print_message warning "Manually add the directory to $config_file (or similar):"
        print_message info "  $command"
    fi
}

XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-$HOME/.config}

current_shell=$(basename "$SHELL")
case $current_shell in
    fish)
        config_files="$HOME/.config/fish/config.fish"
    ;;
    zsh)
        config_files="${ZDOTDIR:-$HOME}/.zshrc ${ZDOTDIR:-$HOME}/.zshenv $XDG_CONFIG_HOME/zsh/.zshrc $XDG_CONFIG_HOME/zsh/.zshenv"
    ;;
    bash)
        config_files="$HOME/.bashrc $HOME/.bash_profile $HOME/.profile $XDG_CONFIG_HOME/bash/.bashrc $XDG_CONFIG_HOME/bash/.bash_profile"
    ;;
    ash)
        config_files="$HOME/.ashrc $HOME/.profile /etc/profile"
    ;;
    sh)
        config_files="$HOME/.ashrc $HOME/.profile /etc/profile"
    ;;
    *)
        # Default case if none of the above matches
        config_files="$HOME/.bashrc $HOME/.bash_profile $XDG_CONFIG_HOME/bash/.bashrc $XDG_CONFIG_HOME/bash/.bash_profile"
    ;;
esac

if [[ "$no_modify_path" != "true" ]]; then
    config_file=""
    for file in $config_files; do
        if [[ -f $file ]]; then
            config_file=$file
            break
        fi
    done

    if [[ -z $config_file ]]; then
        print_message warning "No config file found for $current_shell. You may need to manually add to PATH:"
        print_message info "  export PATH=$INSTALL_DIR:\$PATH"
    elif [[ ":$PATH:" != *":$INSTALL_DIR:"* ]]; then
        case $current_shell in
            fish)
                add_to_path "$config_file" "fish_add_path $INSTALL_DIR"
            ;;
            zsh)
                add_to_path "$config_file" "export PATH=$INSTALL_DIR:\$PATH"
            ;;
            bash)
                add_to_path "$config_file" "export PATH=$INSTALL_DIR:\$PATH"
            ;;
            ash)
                add_to_path "$config_file" "export PATH=$INSTALL_DIR:\$PATH"
            ;;
            sh)
                add_to_path "$config_file" "export PATH=$INSTALL_DIR:\$PATH"
            ;;
            *)
                export PATH=$INSTALL_DIR:$PATH
                print_message warning "Manually add the directory to $config_file (or similar):"
                print_message info "  export PATH=$INSTALL_DIR:\$PATH"
            ;;
        esac
    fi
fi

if [ -n "${GITHUB_ACTIONS-}" ] && [ "${GITHUB_ACTIONS}" == "true" ]; then
    echo "$INSTALL_DIR" >> $GITHUB_PATH
    print_message info "Added $INSTALL_DIR to \$GITHUB_PATH"
fi

echo -e ""
echo -e "\033[38;5;220m█████   █████    ████    █████   ████   ██  ██\033[0m"
echo -e "\033[38;5;220m██  ██  ██  ██  ██  ██  ██      ██  ██  ███ ██\033[0m"
echo -e "\033[38;5;214m██  ██  █████   ██████  ██ ███  ██  ██  ██████\033[0m"
echo -e "\033[38;5;214m██  ██  ██ ██   ██  ██  ██  ██  ██  ██  ██ ███\033[0m"
echo -e "\033[38;5;208m█████   ██  ██  ██  ██   █████   ████   ██  ██\033[0m"
echo -e "\033[38;5;208m         █████   ████   █████   ██████        \033[0m"
echo -e "\033[38;5;202m        ██      ██  ██  ██  ██  ██            \033[0m"
echo -e "\033[38;5;202m        ██      ██  ██  ██  ██  █████         \033[0m"
echo -e "\033[38;5;166m        ██      ██  ██  ██  ██  ██            \033[0m"
echo -e "\033[38;5;166m         █████   ████   █████   ██████        \033[0m"
echo -e ""
echo -e ""
echo -e "${MUTED}DragonCode is installed. To start:${NC}"
echo -e ""
echo -e "cd <project>  ${MUTED}# Open directory${NC}"
echo -e "dragon        ${MUTED}# Run command${NC}"
echo -e ""

# The PATH export was written to a shell config file, but this installer runs in a
# subshell (curl ... | bash) and cannot update the PATH of the interactive shell that
# launched it. Tell the user how to pick it up now. `command -v dragon` is the signal:
# it fails exactly when a reload is needed, and succeeds on reinstall / already-on-PATH.
if { [ -z "${GITHUB_ACTIONS-}" ] || [ "${GITHUB_ACTIONS}" != "true" ]; } \
   && ! command -v dragon >/dev/null 2>&1; then
    if [ -n "${config_file:-}" ]; then
        echo -e "${ORANGE}dragon isn't on your PATH in this shell yet.${NC} Open a new terminal, or run:"
        echo -e "    source $config_file"
    else
        echo -e "${ORANGE}Add dragon to your PATH:${NC}"
        echo -e "    export PATH=$INSTALL_DIR:\$PATH"
    fi
    echo -e ""
fi

echo -e "${MUTED}For more information visit ${NC}https://github.com/VELLORAAI/dragoncode-public-dist"
echo -e ""
echo -e ""
